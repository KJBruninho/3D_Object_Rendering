#version 330 core

in vec3 FragPos;
in vec3 Normal;
in vec2 TexCoord;

out vec4 color;

uniform vec3 lightPos;     // Posiçăo da fonte de luz
uniform vec3 viewPos;      // Posiçăo da câmera
uniform vec3 lightColor;   // Cor da luz
uniform vec3 objectColor;  // Cor do objeto

uniform sampler2D textureSampler;

void main()
{
    // Normalizaçăo das normais e direçăo da luz
    vec3 norm = normalize(Normal);
    vec3 lightDir = normalize(lightPos - FragPos);
    vec3 viewDir = normalize(viewPos - FragPos);
    
    // Luz ambiente
    float ambientStrength = 0.5f;
    vec3 ambient = ambientStrength * lightColor;

    // Luz difusa (Lambert)
    float diff = max(dot(norm, lightDir), 0.0);
    vec3 diffuse = diff * lightColor;

    // Luz especular (Phong)
    float specularStrength = 0.5f;
    vec3 reflectDir = reflect(-lightDir, norm);  
    float spec = pow(max(dot(viewDir, reflectDir), 0.0), 32);
    vec3 specular = specularStrength * spec * lightColor;

    // Cor final do fragmento
    vec3 result = (ambient + diffuse + specular) * objectColor;

    // Usando a textura se disponível
    vec4 textureColor = texture(textureSampler, TexCoord);
    color = vec4(result, 1.0) * textureColor;
}